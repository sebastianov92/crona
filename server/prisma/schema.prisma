generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum InstanceStatus {
  CREATED
  CONNECTING
  CONNECTED
  DISCONNECTED
}

enum RecipientKind {
  CONTACT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AutoReplyAction {
  REPLY
  NOTIFY
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum LogStatus {
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String // argon2id
  name          String
  role          Role     @default(USER)
  ntfyTopic     String? // topic personal, ej. "crona-sebastian-x7k2"
  ntfyToken     String? // opcional si el server ntfy usa auth
  notifyOnSent  Boolean  @default(false) // notificar también envíos exitosos
  chatListCount     Int  @default(10) // cuántos chats mostrar en la pestaña Chats
  chatIncomingCount Int  @default(5) // mensajes recibidos visibles por chat (0 = ninguno)
  defaultInstanceId String? // instancia principal: preseleccionada al programar
  // Botones rápidos Mañana/Tarde/Noche: minutos del día {start,end} por franja.
  // start == end → hora exacta (se envía con +1..5 min aleatorios); si no, hora aleatoria del rango.
  quickHours        Json? // {"morning":{"start":480,"end":540},"afternoon":{...},"evening":{...}}
  createdAt     DateTime @default(now())
  instances     Instance[]
  messages      ScheduledMessage[]
  media         Media[]
  refreshTokens RefreshToken[]
  autoReplies   AutoReply[]
  hiddenChats   HiddenChat[]
  contactLists  ContactList[]
}

// Chat "eliminado" de la pestaña Chats: se oculta hasta que haya actividad nueva
// (mensaje programado/enviado o recibido después de hiddenAt).
model HiddenChat {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceId String
  jid        String
  hiddenAt   DateTime @default(now())

  @@unique([userId, instanceId, jid])
}

// Lista de difusión: varios contactos a los que se programa de una sola vez.
model ContactList {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceId String
  name       String
  createdAt  DateTime            @default(now())
  members    ContactListMember[]
}

model ContactListMember {
  id         String      @id @default(uuid())
  listId     String
  list       ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  jid        String
  name       String
  pictureUrl String?
  kind       RecipientKind @default(CONTACT)

  @@unique([listId, jid])
}

model Invite {
  id          String   @id @default(uuid())
  code        String   @unique // 8 chars aleatorios
  createdById String
  usedById    String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha256 del token
  expiresAt DateTime
  revokedAt DateTime?
}

// Singleton (id = 1). Config global editable solo por ADMIN desde la app.
model ServerSettings {
  id                       Int      @id @default(1)
  evolutionBaseUrl         String // ej. http://evolution-api:8080 (red interna)
  evolutionGlobalApiKeyEnc String // cifrada AES-256-GCM
  ntfyBaseUrl              String   @default("https://ntfy.sh")
  updatedAt                DateTime @updatedAt
}

model Instance {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String // nombre visible: "Personal", "Negocio"
  instanceName    String         @unique // nombre en Evolution: "u{shortid}-personal"
  tokenEnc        String // apikey/hash de la instancia, cifrada
  phoneNumber     String? // se llena al conectar
  profilePicUrl   String?
  status          InstanceStatus @default(CREATED)
  lastConnectedAt DateTime?
  sortOrder       Int            @default(0) // posición en la lista; la primera es la principal
  createdAt       DateTime       @default(now())
  recipients      Recipient[]
  messages        ScheduledMessage[]
  autoReplies     AutoReply[]
  chatMessages    ChatMessage[]
}

// Mensajes recibidos (webhook MESSAGES_UPSERT) — alimentan la pestaña Chats.
// Solo se guardan a partir de que el server los ve; limpieza a 30 días.
model ChatMessage {
  id                 String      @id @default(uuid())
  instanceId         String
  instance           Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  jid                String // contacto (5939…@s.whatsapp.net)
  fromMe             Boolean     @default(false)
  type               MessageType @default(TEXT)
  body               String? // texto o caption; null en media sin caption
  pushName           String?
  evolutionMessageId String?
  sentAt             DateTime
  createdAt          DateTime    @default(now())

  @@index([instanceId, jid, sentAt])
}

// Regla de respuesta automática a mensajes entrantes (webhook MESSAGES_UPSERT)
model AutoReply {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceId      String
  instance        Instance        @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  action          AutoReplyAction @default(REPLY)
  contactJid      String? // null = cualquier contacto; si no, solo dispara con este jid
  contactName     String?
  keyword         String? // null = cualquier mensaje entrante
  replyText       String? // requerido si action = REPLY
  activeFromHour  Int? // 0-23 en `timezone`; null = siempre activa
  activeToHour    Int?
  activeDays      Int[]           @default([]) // ISO 1=lun … 7=dom; vacío = todos los días
  timezone        String          @default("America/Guayaquil")
  cooldownMinutes Int             @default(60) // 1 respuesta por contacto por ventana (anti-spam/anti-ban)
  enabled         Boolean         @default(true)
  createdAt       DateTime        @default(now())
  hits            AutoReplyHit[]
}

model AutoReplyHit {
  id          String    @id @default(uuid())
  autoReplyId String
  autoReply   AutoReply @relation(fields: [autoReplyId], references: [id], onDelete: Cascade)
  jid         String
  createdAt   DateTime  @default(now())

  @@index([autoReplyId, jid, createdAt])
}

// Cache local de contactos y grupos de WhatsApp (se sincroniza bajo demanda)
model Recipient {
  id          String        @id @default(uuid())
  instanceId  String
  instance    Instance      @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  jid         String // "5939XXXXXXXX@s.whatsapp.net" | "1203...@g.us"
  displayName String
  alias       String? // nombre puesto por el usuario en Crona (pushName no siempre es el de su agenda)
  pictureUrl  String?
  kind        RecipientKind
  phoneNumber String? // solo contactos
  syncedAt    DateTime      @default(now())

  @@unique([instanceId, jid])
  @@index([instanceId, kind])
}

model Media {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  sizeBytes   Int
  storagePath String // relativo a MEDIA_DIR
  createdAt   DateTime @default(now())
}

model ScheduledMessage {
  id                  String         @id @default(uuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  instanceId          String
  instance            Instance       @relation(fields: [instanceId], references: [id])
  // snapshot del destinatario (por si luego cambia el cache)
  recipientJid        String
  recipientName       String
  recipientKind       RecipientKind
  recipientPictureUrl String?
  // contenido
  type                MessageType
  body                String? // texto del mensaje o caption del media
  mediaId             String?
  // programación
  timezone            String         @default("America/Guayaquil")
  scheduledAt         DateTime // primera ejecución (UTC)
  recurrence          Recurrence     @default(NONE)
  recurrenceDays      Int[]          @default([]) // 1=lun … 7=dom (ISO), solo WEEKLY
  recurrenceUntil     DateTime?
  nextRunAt           DateTime // = scheduledAt al crear; el worker la recalcula
  status              ScheduleStatus @default(ACTIVE)
  isAutoReply         Boolean        @default(false) // creado por una regla de respuesta automática
  randomDelay         Boolean        @default(false) // recurrentes: variar cada ocurrencia +1..5 min (anti-detección)
  typingMs            Int? // cuánto mostrar "escribiendo…/grabando audio…" antes de enviar (lo que tardó el usuario al redactar)
  attempts            Int            @default(0) // de la ocurrencia actual
  lastError           String?
  claimedAt           DateTime? // claim del worker (§17); NULL cuando no está en proceso
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  logs                MessageLog[]

  @@index([status, nextRunAt])
  @@index([userId, status])
}

// Una fila por cada envío real ejecutado (historial). Estados actualizados por webhooks.
model MessageLog {
  id                 String           @id @default(uuid())
  scheduledMessageId String
  scheduledMessage   ScheduledMessage @relation(fields: [scheduledMessageId], references: [id], onDelete: Cascade)
  runAt              DateTime
  status             LogStatus
  evolutionMessageId String? // response.key.id — clave para matchear webhooks
  remoteJid          String
  error              String?
  sentAt             DateTime?
  deliveredAt        DateTime?
  readAt             DateTime?
  createdAt          DateTime         @default(now())

  @@index([evolutionMessageId])
}

// Opcional (debug): guardar webhooks crudos los primeros días; job de limpieza a 7 días.
model WebhookEventRaw {
  id           String   @id @default(uuid())
  instanceName String
  event        String
  payload      Json
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

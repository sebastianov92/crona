<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <!-- SIN App Sandbox: el auto-actualizador necesita reemplazar Crona.app en /Aplicaciones
       y quitar la cuarentena del bundle descargado. El sandbox solo es obligatorio en la
       App Store; para distribución directa (DMG con firma ad-hoc) es opcional. -->
  <key>com.apple.security.app-sandbox</key><false/>
  <!-- grabar notas de voz -->
  <key>com.apple.security.device.audio-input</key><true/>
  <!-- SIN App Group: tocar su contenedor sin sandbox dispara el aviso "acceder a datos de
       otras apps" en cada actualización. El widget queda solo en iPhone/iPad. -->
</dict></plist>
